# ─────────────────────────────────────────────────────────────
#  業界ブリーフィング Bot  環境変数サンプル
#  このファイルをコピーして .env.local を作成してください:
#    cp .env.local.example .env.local
#  .env.local は .gitignore 済み（絶対にコミットしない）
# ─────────────────────────────────────────────────────────────

# LLM バックエンドの選択:
#   cli ... 端末の `claude` CLI（Claude Pro/Max サブスク認証・API課金なし）を使う【VPS推奨・既定】
#   api ... Anthropic API（@anthropic-ai/sdk・従量課金）を使う【Vercel等で利用】
LLM_PROVIDER=cli

# ── LLM_PROVIDER=api のときのみ必要 ──────────────────────────
# Anthropic コンソールで取得した API キー。フロントには絶対に出ない（サーバー側のみ）。
ANTHROPIC_API_KEY=

# ── LLM_PROVIDER=cli のときの任意設定 ───────────────────────
# claude 実行ファイルのパス（PATH に通っていれば未設定でOK）
# CLAUDE_BIN=/usr/local/bin/claude
# CLI のホーム（subscription 認証情報の場所。pm2 等で HOME が変わる場合に指定）
# CLAUDE_HOME=/root

# 使用モデル（両プロバイダ共通・既定 claude-sonnet-4-6）
CLAUDE_MODEL=claude-sonnet-4-6
